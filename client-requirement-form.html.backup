    <!-- Loader Overlay -->
    <div class="loader-overlay" id="loaderOverlay">
        <div class="loader"></div>
        <div class="loader-text">Submitting your form...</div>
    </div>

    <!-- Auto-Save Indicator -->
    <div class="auto-save-indicator" id="autoSaveIndicator">✓ Auto-saved</div>

    <script>
        // ============================================
        // AUTO-SAVE FEATURE
        // ============================================
        const STORAGE_KEY = 'clientFormData';
        const CLIENT_ID_KEY = 'generatedClientId';
        let saveTimeout;

        // Generate unique client ID
        function generateClientId() {
            const existingId = localStorage.getItem(CLIENT_ID_KEY);
            console.log('Existing client ID from localStorage:', existingId);
            
            if (existingId) {
                console.log('Using existing client ID:', existingId);
                return existingId;
            }

            const year = new Date().getFullYear();
            const randomNum = Math.floor(Math.random() * 9999) + 1;
            const clientId = `CL-${year}-${randomNum.toString().padStart(4, '0')}`;
            
            console.log('Generated new client ID:', clientId);
            localStorage.setItem(CLIENT_ID_KEY, clientId);
            return clientId;
        }

        function saveFormData() {
            const form = document.getElementById('requirementForm');
            const formData = new FormData(form);
            const data = {};

            // Add client ID to data
            const clientId = generateClientId();
            data.client_id = clientId;
            console.log('Form submission - Client ID added:', clientId);

            // Handle regular form fields
            formData.forEach((value, key) => {
                if (data[key]) {
                    if (Array.isArray(data[key])) {
                        data[key].push(value);
                    } else {
                        data[key] = [data[key], value];
                    }
                } else {
                    data[key] = value;
                }
            });

            // Handle checkboxes separately
            const checkboxes = form.querySelectorAll('input[type="checkbox"]:checked');
            checkboxes.forEach(checkbox => {
                if (data[checkbox.name]) {
                    if (Array.isArray(data[checkbox.name])) {
                        data[checkbox.name].push(checkbox.value);
                    } else {
                        data[checkbox.name] = [data[checkbox.name], checkbox.value];
                    }
                } else {
                    data[checkbox.name] = checkbox.value;
                }
            });

            // Handle radio buttons
            const radioGroups = {};
            const radios = form.querySelectorAll('input[type="radio"]:checked');
            radios.forEach(radio => {
                radioGroups[radio.name] = radio.value;
            });

            // Merge radio data
            Object.assign(data, radioGroups);

            // Add timestamp
            data.timestamp = new Date().toISOString();

            // Save to localStorage
            localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
            
            // Show auto-save indicator
            showAutoSaveIndicator();
        }

        function loadFormData() {
            const savedData = localStorage.getItem(STORAGE_KEY);
            if (savedData) {
                const data = JSON.parse(savedData);
                const form = document.getElementById('requirementForm');

                // Restore regular form fields
                Object.keys(data).forEach(key => {
                    if (key === 'client_id' || key === 'timestamp') return; // Skip metadata
                    if (key === 'hasDomain' || key === 'hasHosting' || key === 'hasLogo' || key === 'isEcommerce') return; // Skip domain/hosting/logo/ecommerce to prevent default selection
                    
                    const value = data[key];
                    const field = form.querySelector(`[name="${key}"]`);
                    
                    if (field) {
                        if (field.type === 'radio') {
                            const radio = form.querySelector(`[name="${key}"][value="${value}"]`);
                            if (radio) radio.checked = true;
                        } else if (field.type === 'checkbox') {
                            if (Array.isArray(value)) {
                                value.forEach(val => {
                                    const checkbox = form.querySelector(`[name="${key}"][value="${val}"]`);
                                    if (checkbox) checkbox.checked = true;
                                });
                            } else {
                                const checkbox = form.querySelector(`[name="${key}"][value="${value}"]`);
                                if (checkbox) checkbox.checked = true;
                            }
                        } else if (field.type === 'file') {
                            // Skip file inputs
                            return;
                        } else {
                            field.value = value;
                        }
                    }
                });

                // Trigger change events to update conditional fields
                const inputs = form.querySelectorAll('input, select, textarea');
                inputs.forEach(input => {
                    input.dispatchEvent(new Event('change'));
                });

                // Update dynamic content fields
                updateDynamicContentFields();
                updateNavigationList();
                updatePageCount();
            }
        }

        function clearSavedData() {
            if (confirm('Are you sure you want to clear all saved form data?')) {
                localStorage.removeItem(STORAGE_KEY);
                localStorage.removeItem(CLIENT_ID_KEY);
                location.reload();
            }
        }

        function debouncedSave() {
            clearTimeout(saveTimeout);
            saveTimeout = setTimeout(saveFormData, 1000);
        }

        function showAutoSaveIndicator() {
            const indicator = document.createElement('div');
            indicator.className = 'auto-save-indicator show';
            indicator.textContent = 'Auto-saved';
            document.body.appendChild(indicator);

            setTimeout(() => {
                indicator.classList.remove('show');
                setTimeout(() => {
                    if (document.body.contains(indicator)) {
                        document.body.removeChild(indicator);
                    }
                }, 300);
            }, 2000);
            autoSaveTimeout = setTimeout(saveFormData, AUTO_SAVE_DELAY);
        }

        // ============================================
        // GLOBAL FUNCTIONS
        // ============================================
        // Global function for adding page to checkbox group
        function addPageToCheckboxGroup(btn) {
            const pageDiv = btn.closest('.dynamic-item');
            const pageNameInput = pageDiv.querySelector('input[name^="additionalPageName_"]');
            const pageTypeSelect = pageDiv.querySelector('select[name^="additionalPageType_"]');
            const pageName = pageNameInput.value.trim();
            const pageType = pageTypeSelect ? pageTypeSelect.value : 'header';

            const checkboxGroup = document.querySelector(`input[name="${pageType}Pages"]`).closest('.checkbox-group');
            const existingCheckbox = checkboxGroup.querySelector(`input[value="${pageName.toLowerCase().replace(/\s+/g, '-')}"]`);

            if (pageName && !existingCheckbox) {
                const checkboxLabel = document.createElement('label');
                checkboxLabel.className = 'checkbox-option';
                checkboxLabel.innerHTML = `
                    <input type="checkbox" name="${pageType}Pages" value="${pageName.toLowerCase().replace(/\s+/g, '-')}" checked> ${pageName}
                `;
                checkboxGroup.appendChild(checkboxLabel);

                // Add event listener to the new checkbox
                const newCheckbox = checkboxLabel.querySelector('input');
                newCheckbox.addEventListener('change', function() {
                    updateDynamicContentFields();
                    updateNavigationList();
                    updatePageCount();
                });

                updateDynamicContentFields();
                updateNavigationList();
                updatePageCount();
                btn.textContent = 'Added ✓';
                btn.disabled = true;
            } else if (!pageName) {
                alert('Please enter a page name first');
            } else {
                alert('This page already exists in Website Structure');
            }
        }

        // Global function for updating page count badge
        function updatePageCount() {
            const headerPagesCheckboxes = document.querySelectorAll('input[name="headerPages"]:checked');
            const footerPagesCheckboxes = document.querySelectorAll('input[name="footerPages"]:checked');
            const totalCount = headerPagesCheckboxes.length + footerPagesCheckboxes.length;
            const badge = document.getElementById('pageCountBadge');
            if (badge) {
                badge.textContent = `(${totalCount} page${totalCount !== 1 ? 's' : ''})`;
            }
        }

        // Global function for updating dynamic content fields with TAB UI
        function updateDynamicContentFields() {
            const dynamicContentFields = document.getElementById('dynamicContentFields');
            const pageContentTabs = document.getElementById('pageContentTabs');
            const headerPagesCheckboxes = document.querySelectorAll('input[name="headerPages"]');
            const footerPagesCheckboxes = document.querySelectorAll('input[name="footerPages"]');

            // Clear existing fields
            dynamicContentFields.innerHTML = '';
            pageContentTabs.innerHTML = '';

            // Get all selected pages
            const selectedPages = [];
            headerPagesCheckboxes.forEach(checkbox => {
                if (checkbox.checked) {
                    selectedPages.push({
                        value: checkbox.value,
                        label: checkbox.parentElement.textContent.trim()
                    });
                }
            });
            footerPagesCheckboxes.forEach(checkbox => {
                if (checkbox.checked) {
                    selectedPages.push({
                        value: checkbox.value,
                        label: checkbox.parentElement.textContent.trim()
                    });
                }
            });

            // If no pages selected, show message
            if (selectedPages.length === 0) {
                dynamicContentFields.innerHTML = '<p style="color: #6c757d; font-style: italic;">Please select pages from Website Structure to add content.</p>';
                return;
            }

            // Create tabs
            selectedPages.forEach((page, index) => {
                const tabBtn = document.createElement('button');
                tabBtn.type = 'button';
                tabBtn.className = 'page-tab-btn' + (index === 0 ? ' active' : '');
                tabBtn.dataset.page = page.value;
                tabBtn.innerHTML = `
                    <span class="tab-label">${page.label}</span>
                    <span class="tab-tick" style="display: none;">✓</span>
                `;
                tabBtn.addEventListener('click', () => switchPageTab(page.value));
                pageContentTabs.appendChild(tabBtn);
            });

            // Create content sections for each page
            selectedPages.forEach((page, index) => {
                const contentDiv = document.createElement('div');
                contentDiv.className = 'page-content-panel' + (index === 0 ? ' active' : '');
                contentDiv.dataset.page = page.value;

                // Check if this is the Contact page
                if (page.value === 'contact') {
                    contentDiv.innerHTML = getContactFormBuilderHTML(page.label);
                } else {
                    contentDiv.innerHTML = getRegularPageContentHTML(page);
                }

                dynamicContentFields.appendChild(contentDiv);
            });

            // Initialize contact form builder if contact page exists
            const contactPanel = document.querySelector('.page-content-panel[data-page="contact"]');
            if (contactPanel) {
                initContactFormBuilder();
            }

            // Add input listeners for completion ticks
            addPageCompletionListeners();
        }

        // Function to switch between page tabs
        function switchPageTab(pageValue) {
            // Update tab buttons
            document.querySelectorAll('.page-tab-btn').forEach(btn => {
                btn.classList.remove('active');
                if (btn.dataset.page === pageValue) {
                    btn.classList.add('active');
                }
            });

            // Update content panels
            document.querySelectorAll('.page-content-panel').forEach(panel => {
                panel.classList.remove('active');
                if (panel.dataset.page === pageValue) {
                    panel.classList.add('active');
                }
            });
        }

        // Function to add completion listeners to page inputs
        function addPageCompletionListeners() {
            document.querySelectorAll('.page-input, .contact-form-input, .custom-field-input').forEach(input => {
                input.addEventListener('input', updatePageCompletionTicks);
                input.addEventListener('change', updatePageCompletionTicks);
            });
        }

        // Function to get regular page content HTML
        function getRegularPageContentHTML(page) {
            return `
                <div class="page-content-header">
                    <h4>${page.label} Page Content</h4>
                </div>
                <div class="row">
                    <div class="form-group">
                        <label>Page Heading</label>
                        <input type="text" name="pageHeading_${page.value}" placeholder="Main heading for ${page.label} page" class="page-input" data-page="${page.value}">
                    </div>
                    <div class="form-group">
                        <label>Page Subheading</label>
                        <input type="text" name="pageSubheading_${page.value}" placeholder="Subheading for ${page.label} page" class="page-input" data-page="${page.value}">
                    </div>
                </div>
                <div class="form-group">
                    <label>Page Content</label>
                    <textarea name="content_${page.value}" placeholder="Detailed content for ${page.label} page..." rows="6" class="page-input" data-page="${page.value}"></textarea>
                </div>
                <div class="form-group">
                    <label>Page Image</label>
                    <div class="file-upload">
                        <input type="file" name="pageImage_${page.value}" accept="image/*" class="file-input page-input" data-page="${page.value}">
                        <span class="file-name">No image selected</span>
                        <small style="color: #6c757d; margin-top: 5px; display: block;">Upload main image for ${page.label} page (JPG, PNG, GIF)</small>
                    </div>
                </div>
                <div class="form-group">
                    <label>Or upload content file (PDF, Excel, Word):</label>
                    <div class="file-upload">
                        <input type="file" name="content_${page.value}_file" accept=".pdf,.xlsx,.xls,.doc,.docx" class="file-input page-input" data-page="${page.value}">
                        <span class="file-name">No file selected</span>
                    </div>
                </div>
            `;
        }

        // Function to get Contact Form builder HTML
        function getContactFormBuilderHTML(pageLabel) {
            return `
                <div class="page-content-header">
                    <h4>${pageLabel} Page - Contact Form Builder</h4>
                    <p style="color: #6c757d; font-size: 0.9rem; margin-top: 5px;">Configure the contact form fields and settings</p>
                </div>

                <!-- Form Settings -->
                <div class="contact-form-section">
                    <h5 style="color: #2c3e50; margin-bottom: 15px; border-bottom: 2px solid #3498db; padding-bottom: 8px;">Form Settings</h5>
                    <div class="row">
                        <div class="form-group">
                            <label>Form Title</label>
                            <input type="text" name="contactFormTitle" placeholder="e.g., Get in Touch" class="page-input" data-page="contact">
                        </div>
                        <div class="form-group">
                            <label>Submit Button Text</label>
                            <input type="text" name="contactFormSubmitText" placeholder="e.g., Send Message" class="page-input" data-page="contact">
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Thank You Message</label>
                        <textarea name="contactFormThankYou" placeholder="Message to show after form submission..." rows="3" class="page-input" data-page="contact"></textarea>
                    </div>
                    <div class="form-group">
                        <label>Admin Email (where form will be received)</label>
                        <input type="email" name="contactFormAdminEmail" placeholder="admin@example.com" class="page-input" data-page="contact">
                    </div>
                </div>

                <!-- Standard Fields -->
                <div class="contact-form-section">
                    <h5 style="color: #2c3e50; margin-bottom: 15px; border-bottom: 2px solid #3498db; padding-bottom: 8px;">Standard Fields</h5>
                    <div class="contact-field-grid">
                        <label class="contact-field-checkbox">
                            <input type="checkbox" name="contactField_name" value="yes" class="contact-form-input" data-page="contact">
                            <span class="field-icon">👤</span>
                            <span class="field-label">Name Field</span>
                        </label>
                        <label class="contact-field-checkbox">
                            <input type="checkbox" name="contactField_email" value="yes" class="contact-form-input" data-page="contact">
                            <span class="field-icon">✉️</span>
                            <span class="field-label">Email Field</span>
                        </label>
                        <label class="contact-field-checkbox">
                            <input type="checkbox" name="contactField_phone" value="yes" class="contact-form-input" data-page="contact">
                            <span class="field-icon">📞</span>
                            <span class="field-label">Phone Field</span>
                        </label>
                        <label class="contact-field-checkbox">
                            <input type="checkbox" name="contactField_message" value="yes" class="contact-form-input" data-page="contact">
                            <span class="field-icon">📝</span>
                            <span class="field-label">Message Field</span>
                        </label>
                    </div>
                </div>

                <!-- Custom Fields -->
                <div class="contact-form-section">
                    <h5 style="color: #2c3e50; margin-bottom: 15px; border-bottom: 2px solid #3498db; padding-bottom: 8px;">Custom Fields</h5>
                    <div id="customFieldsContainer"></div>
                    <button type="button" id="addCustomFieldBtn" class="add-custom-field-btn">
                        <span>+</span> Add Custom Field
                    </button>
                </div>
            `;
        }

        // Function to initialize Contact Form Builder
        function initContactFormBuilder() {
            const addCustomFieldBtn = document.getElementById('addCustomFieldBtn');
            const customFieldsContainer = document.getElementById('customFieldsContainer');

            if (addCustomFieldBtn && customFieldsContainer) {
                addCustomFieldBtn.addEventListener('click', function() {
                    addCustomField();
                });
            }
        }

        // Function to add a custom field
        function addCustomField() {
            const container = document.getElementById('customFieldsContainer');
            const fieldIndex = container.children.length;

            const customFieldDiv = document.createElement('div');
            customFieldDiv.className = 'custom-field-row';
            customFieldDiv.innerHTML = `
                <div class="custom-field-inputs">
                    <div class="form-group">
                        <label>Field Label</label>
                        <input type="text" name="contactCustomField_${fieldIndex}_label" placeholder="e.g., Budget, Service Type" class="custom-field-input" data-page="contact">
                    </div>
                    <div class="form-group">
                        <label>Field Type</label>
                        <select name="contactCustomField_${fieldIndex}_type" class="custom-field-input" data-page="contact">
                            <option value="text">Text Input</option>
                            <option value="number">Number</option>
                            <option value="textarea">Textarea (Multi-line)</option>
                            <option value="email">Email</option>
                            <option value="tel">Phone</option>
                            <option value="date">Date</option>
                            <option value="select">Dropdown Select</option>
                        </select>
                    </div>
                </div>
                <button type="button" class="remove-custom-field-btn" onclick="removeCustomField(this)">×</button>
            `;

            container.appendChild(customFieldDiv);

            // Add listeners to new inputs
            customFieldDiv.querySelectorAll('.custom-field-input').forEach(input => {
                input.addEventListener('input', updatePageCompletionTicks);
                input.addEventListener('change', updatePageCompletionTicks);
            });
        }

        // Function to remove a custom field
        function removeCustomField(btn) {
            const row = btn.closest('.custom-field-row');
            if (row) {
                row.remove();
                updatePageCompletionTicks();
            }
        }

        // Function to update completion tick indicators
        function updatePageCompletionTicks() {
            document.querySelectorAll('.page-content-panel').forEach(panel => {
                const pageValue = panel.dataset.page;
                const inputs = panel.querySelectorAll('.page-input');
                let hasContent = false;

                inputs.forEach(input => {
                    if (input.type === 'file') {
                        if (input.files && input.files.length > 0) {
                            hasContent = true;
                        }
                    } else {
                        if (input.value.trim() !== '') {
                            hasContent = true;
                        }
                    }
                });

                // Update tick on corresponding tab
                const tabBtn = document.querySelector(`.page-tab-btn[data-page="${pageValue}"]`);
                if (tabBtn) {
                    const tick = tabBtn.querySelector('.tab-tick');
                    if (tick) {
                        tick.style.display = hasContent ? 'inline' : 'none';
                    }
                }
            });
        }

        // Global function for updating navigation list
        function updateNavigationList() {
            const navigationList = document.getElementById('navigationList');
            const navigationStructureInput = document.getElementById('navigationStructureInput');
            const headerPagesCheckboxes = document.querySelectorAll('input[name="headerPages"]');
            const footerPagesCheckboxes = document.querySelectorAll('input[name="footerPages"]');
            const selectedPages = [];

            // Get all selected pages from headerPages checkboxes
            headerPagesCheckboxes.forEach(checkbox => {
                if (checkbox.checked) {
                    selectedPages.push({
                        value: checkbox.value,
                        label: checkbox.parentElement.textContent.trim(),
                        type: 'header'
                    });
                }
            });

            // Get all selected pages from footerPages checkboxes
            footerPagesCheckboxes.forEach(checkbox => {
                if (checkbox.checked) {
                    selectedPages.push({
                        value: checkbox.value,
                        label: checkbox.parentElement.textContent.trim(),
                        type: 'footer'
                    });
                }
            });

            // Clear existing navigation list
            navigationList.innerHTML = '';

            // Create navigation items
            selectedPages.forEach((page, index) => {
                const navItem = document.createElement('div');
                navItem.className = 'navigation-item';
                navItem.draggable = true;
                navItem.dataset.value = page.value;
                navItem.dataset.type = page.type;
                navItem.innerHTML = `
                    <span class="drag-handle">⋮⋮</span>
                    <span class="page-name">${page.label} (${page.type})</span>
                    <span class="remove-btn" onclick="removeFromNavigation('${page.value}', '${page.type}')">×</span>
                `;

                // Add drag events
                navItem.addEventListener('dragstart', handleDragStart);
                navItem.addEventListener('dragend', handleDragEnd);
                navItem.addEventListener('dragover', handleDragOver);
                navItem.addEventListener('drop', handleDrop);

                navigationList.appendChild(navItem);
            });

            // Update hidden input with current order
            updateNavigationStructureInput();
        }

        function removeFromNavigation(pageValue, pageType) {
            const checkbox = document.querySelector(`input[name="${pageType}Pages"][value="${pageValue}"]`);
            if (checkbox) {
                checkbox.checked = false;
                updateDynamicContentFields();
                updateNavigationList();
                updatePageCount();
            }
        }

        function updateNavigationStructureInput() {
            const navigationList = document.getElementById('navigationList');
            const navigationStructureInput = document.getElementById('navigationStructureInput');
            const items = navigationList.querySelectorAll('.navigation-item');
            const order = Array.from(items).map(item => item.dataset.value);
            navigationStructureInput.value = order.join(',');
        }

        let draggedItem = null;

        function handleDragStart(e) {
            draggedItem = this;
            this.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
        }

        function handleDragEnd(e) {
            this.classList.remove('dragging');
            draggedItem = null;
            updateNavigationStructureInput();
        }

        function handleDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            return false;
        }

        function handleDrop(e) {
            e.preventDefault();
            if (this !== draggedItem) {
                const navigationList = document.getElementById('navigationList');
                const allItems = Array.from(navigationList.querySelectorAll('.navigation-item'));
                const draggedIndex = allItems.indexOf(draggedItem);
                const targetIndex = allItems.indexOf(this);

                if (draggedIndex < targetIndex) {
                    this.parentNode.insertBefore(draggedItem, this.nextSibling);
                } else {
                    this.parentNode.insertBefore(draggedItem, this);
                }
            }
            return false;
        }

        // Sidebar navigation logic
        document.addEventListener('DOMContentLoaded', function() {
            // Load saved data on page load
            loadFormData();

            // Add auto-save event listeners to all form inputs
            const form = document.getElementById('requirementForm');
            if (form) {
                const inputs = form.querySelectorAll('input, textarea, select');
                inputs.forEach(input => {
                    input.addEventListener('input', debouncedSave);
                    input.addEventListener('change', debouncedSave);
                });
            }

            // Add Clear Saved Data button to sidebar
            const sidebar = document.querySelector('.sidebar');
            if (sidebar) {
                const clearBtn = document.createElement('button');
                clearBtn.className = 'clear-data-btn';
                clearBtn.textContent = 'Clear Saved Data';
                clearBtn.onclick = clearSavedData;
                sidebar.appendChild(clearBtn);
            }

            // Color picker functionality
            const colorPicker = document.getElementById('colorPicker');
            const colorInput = document.getElementById('colorInput');

            if (colorPicker && colorInput) {
                // When color is picked, update text input
                colorPicker.addEventListener('input', function() {
                    colorInput.value = this.value;
                    debouncedSave();
                });

                // When hex code is typed, update color picker
                colorInput.addEventListener('input', function() {
                    const hexValue = this.value;
                    if (/^#[0-9A-Fa-f]{6}$/.test(hexValue)) {
                        colorPicker.value = hexValue;
                    }
                    debouncedSave();
                });
            }

            const navLinks = document.querySelectorAll('.nav-link');
            const sections = document.querySelectorAll('.form-section');
            const sectionHeaders = document.querySelectorAll('.section-header');

            // Sidebar navigation click
            navLinks.forEach(link => {
                link.addEventListener('click', function(e) {
                    e.preventDefault();

                    const targetSection = this.dataset.section;
                    const targetEl = document.getElementById(targetSection);

                    // Update active nav link
                    navLinks.forEach(l => l.classList.remove('active'));
                    this.classList.add('active');

                    // Show target section
                    sections.forEach(section => {
                        section.classList.remove('active');
                        if (section.id === targetSection) {
                            section.classList.add('active');
                        }
                    });

                    // Scroll to top of form content
                    document.querySelector('.form-content').scrollTo({ top: 0, behavior: 'smooth' });
                });
            });

            // Section collapse/expand
            sectionHeaders.forEach(header => {
                header.addEventListener('click', function() {
                    const section = this.closest('.form-section');
                    const content = section.querySelector('.section-content');
                    const toggle = this.querySelector('.section-toggle');

                    content.style.display = content.style.display === 'none' ? 'block' : 'none';
                    toggle.classList.toggle('collapsed');
                });
            });

            // Navigation button clicks (Previous/Next)
            const navButtons = document.querySelectorAll('.nav-btn');
            navButtons.forEach(btn => {
                btn.addEventListener('click', function() {
                    const prevSection = this.dataset.prev;
                    const nextSection = this.dataset.next;

                    if (prevSection) {
                        navigateToSection(prevSection);
                    } else if (nextSection) {
                        navigateToSection(nextSection);
                    }
                });
            });

            function navigateToSection(sectionId) {
                const targetEl = document.getElementById(sectionId);

                // Update active nav link in sidebar
                navLinks.forEach(l => l.classList.remove('active'));
                const activeLink = document.querySelector(`.nav-link[data-section="${sectionId}"]`);
                if (activeLink) {
                    activeLink.classList.add('active');
                }

                // Show target section
                sections.forEach(section => {
                    section.classList.remove('active');
                    if (section.id === sectionId) {
                        section.classList.add('active');
                    }
                });

                // Scroll to top of form content
                window.scrollTo({ top: 0, behavior: 'smooth' });

                // Save current section
                debouncedSave();
            }

            // Dynamic show/hide logic
            // Project Type
            const projectTypeSelect = document.querySelector('select[name="projectType"]');
            const otherProjectType = document.getElementById('otherProjectType');

            projectTypeSelect.addEventListener('change', function() {
                if (this.value === 'other') {
                    otherProjectType.classList.add('show');
                } else {
                    otherProjectType.classList.remove('show');
                }
            });

            // Initialize project type field visibility
            if (projectTypeSelect.value === 'other') {
                otherProjectType.classList.add('show');
            } else {
                otherProjectType.classList.remove('show');
            }

            // Business Category
            const businessCategorySelect = document.querySelector('select[name="businessCategory"]');
            const otherBusinessCategory = document.getElementById('otherBusinessCategory');

            businessCategorySelect.addEventListener('change', function() {
                if (this.value === 'other') {
                    otherBusinessCategory.classList.add('show');
                } else {
                    otherBusinessCategory.classList.remove('show');
                }
            });

            // Initialize business category field visibility
            if (businessCategorySelect.value === 'other') {
                otherBusinessCategory.classList.add('show');
            } else {
                otherBusinessCategory.classList.remove('show');
            }

            // Content Ready
            const contentReadyRadios = document.querySelectorAll('input[name="contentReady"]');
            const contentFieldsContainer = document.getElementById('contentFieldsContainer');

            contentReadyRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'no') {
                        contentFieldsContainer.classList.remove('show');
                    } else {
                        contentFieldsContainer.classList.add('show');
                    }
                });
            });

            // Initialize content fields visibility
            const contentReadyChecked = document.querySelector('input[name="contentReady"]:checked');
            if (contentReadyChecked && contentReadyChecked.value === 'no') {
                contentFieldsContainer.classList.remove('show');
            } else {
                contentFieldsContainer.classList.add('show');
            }

            // Sell Type (Products/Services)
            const sellTypeRadios = document.querySelectorAll('input[name="sellType"]');
            const productsSection = document.getElementById('productsSection');
            const servicesSection = document.getElementById('servicesSection');

            sellTypeRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'products' || this.value === 'both') {
                        productsSection.classList.add('show');
                    } else {
                        productsSection.classList.remove('show');
                    }

                    if (this.value === 'services' || this.value === 'both') {
                        servicesSection.classList.add('show');
                    } else {
                        servicesSection.classList.remove('show');
                    }
                });
            });

            // Initialize products and services section visibility
            const sellTypeChecked = document.querySelector('input[name="sellType"]:checked');
            if (sellTypeChecked && (sellTypeChecked.value === 'products' || sellTypeChecked.value === 'both')) {
                productsSection.classList.add('show');
            } else {
                productsSection.classList.remove('show');
            }

            if (sellTypeChecked && (sellTypeChecked.value === 'services' || sellTypeChecked.value === 'both')) {
                servicesSection.classList.add('show');
            } else {
                servicesSection.classList.remove('show');
            }

            // Domain
            const domainRadios = document.querySelectorAll('input[name="hasDomain"]');
            const domainYes = document.getElementById('domainYes');
            const domainNo = document.getElementById('domainNo');
            
            domainRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        domainYes.classList.add('show');
                        domainNo.classList.remove('show');
                    } else if (this.value === 'no') {
                        domainYes.classList.remove('show');
                        domainNo.classList.add('show');
                    }
                });
            });

            // Domain Login Details
            const domainLoginRadios = document.querySelectorAll('input[name="domainLogin"]');
            const domainLoginDetails = document.getElementById('domainLoginDetails');
            
            domainLoginRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        domainLoginDetails.classList.add('show');
                    } else {
                        domainLoginDetails.classList.remove('show');
                    }
                });
            });

            // Hosting
            const hostingRadios = document.querySelectorAll('input[name="hasHosting"]');
            const hostingYes = document.getElementById('hostingYes');
            const hostingNo = document.getElementById('hostingNo');
            
            hostingRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        hostingYes.classList.add('show');
                        hostingNo.classList.remove('show');
                    } else if (this.value === 'no') {
                        hostingYes.classList.remove('show');
                        hostingNo.classList.add('show');
                    }
                });
            });

            // Hosting Login Details
            const hostingLoginRadios = document.querySelectorAll('input[name="hostingLogin"]');
            const hostingLoginDetails = document.getElementById('hostingLoginDetails');
            
            hostingLoginRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        hostingLoginDetails.classList.add('show');
                    } else {
                        hostingLoginDetails.classList.remove('show');
                    }
                });
            });

            // Theme
            const themeRadios = document.querySelectorAll('input[name="hasTheme"]');
            const themeYes = document.getElementById('themeYes');
            const themeNo = document.getElementById('themeNo');

            themeRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        themeYes.classList.add('show');
                        themeNo.classList.remove('show');
                    } else if (this.value === 'no') {
                        themeNo.classList.add('show');
                        themeYes.classList.remove('show');
                    }
                });
            });

            // Platform Selection - Shopify
            const platformSelect = document.querySelector('select[name="platform"]');
            const shopifyDetails = document.getElementById('shopifyDetails');

            if (platformSelect) {
                platformSelect.addEventListener('change', function() {
                    if (this.value === 'shopify') {
                        shopifyDetails.classList.add('show');
                    } else {
                        shopifyDetails.classList.remove('show');
                    }
                });
            }

            // Shopify Login Details
            const shopifyAccountRadios = document.querySelectorAll('input[name="hasShopifyAccount"]');
            const shopifyLoginDetails = document.getElementById('shopifyLoginDetails');

            shopifyAccountRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        shopifyLoginDetails.classList.add('show');
                    } else {
                        shopifyLoginDetails.classList.remove('show');
                    }
                });
            });

            // Logo
            const logoRadios = document.querySelectorAll('input[name="hasLogo"]');
            const logoYes = document.getElementById('logoYes');
            const logoNo = document.getElementById('logoNo');

            logoRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        logoYes.classList.add('show');      // Show upload option only
                        logoNo.classList.remove('show');     // Hide size & colors
                    } else if (this.value === 'no') {
                        logoYes.classList.remove('show');     // Hide upload option
                        logoNo.classList.add('show');       // Show size & colors
                    } else {
                        logoYes.classList.remove('show');
                        logoNo.classList.remove('show');
                    }
                });
            });

            // Company Details Checkbox
            const addCompanyDetailsCheckbox = document.getElementById('addCompanyDetails');
            const companyDetailsSection = document.getElementById('companyDetailsSection');

            if (addCompanyDetailsCheckbox && companyDetailsSection) {
                addCompanyDetailsCheckbox.addEventListener('change', function() {
                    if (this.checked) {
                        companyDetailsSection.classList.add('show');
                    } else {
                        companyDetailsSection.classList.remove('show');
                    }
                });

                // Initialize company details visibility on page load
                if (addCompanyDetailsCheckbox.checked) {
                    companyDetailsSection.classList.add('show');
                } else {
                    companyDetailsSection.classList.remove('show');
                }
            }

            // Ecommerce
            const ecommerceRadios = document.querySelectorAll('input[name="isEcommerce"]');
            const ecommerceYes = document.getElementById('ecommerceYes');
            
            ecommerceRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        ecommerceYes.classList.add('show');
                    } else {
                        ecommerceYes.classList.remove('show');
                    }
                });
            });

            // Payment Methods
            const paymentCheckboxes = document.querySelectorAll('input[name="paymentMethods"]');
            const razorpayDetails = document.getElementById('razorpayDetails');
            const stripeDetails = document.getElementById('stripeDetails');
            const paypalDetails = document.getElementById('paypalDetails');
            const otherPaymentDetails = document.getElementById('otherPaymentDetails');
            
            paymentCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    if (this.value === 'razorpay') {
                        razorpayDetails.classList.toggle('show', this.checked);
                    }
                    if (this.value === 'stripe') {
                        stripeDetails.classList.toggle('show', this.checked);
                    }
                    if (this.value === 'paypal') {
                        paypalDetails.classList.toggle('show', this.checked);
                    }
                    if (this.value === 'other') {
                        otherPaymentDetails.classList.toggle('show', this.checked);
                    }
                });
            });

            // Currencies
            const currencyCheckboxes = document.querySelectorAll('input[name="currencies"]');
            const otherCurrency = document.getElementById('otherCurrency');
            
            currencyCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    if (this.value === 'other') {
                        otherCurrency.classList.toggle('show', this.checked);
                    }
                });
            });

            // Shipping Type
            const shippingSelect = document.querySelector('select[name="shippingType"]');
            const flatRateDetails = document.getElementById('flatRateDetails');
            
            if (shippingSelect) {
                shippingSelect.addEventListener('change', function() {
                    flatRateDetails.classList.toggle('show', this.value === 'flat');
                });
            }

            // Google Analytics
            const analyticsRadios = document.querySelectorAll('input[name="hasAnalytics"]');
            const analyticsYes = document.getElementById('analyticsYes');
            const analyticsSetup = document.getElementById('analyticsSetup');

            analyticsRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        analyticsYes.classList.add('show');
                        analyticsSetup.classList.remove('show');
                    } else if (this.value === 'no') {
                        analyticsSetup.classList.add('show');
                        analyticsYes.classList.remove('show');
                    } else {
                        analyticsYes.classList.remove('show');
                        analyticsSetup.classList.remove('show');
                    }
                });
            });

            // Legal Documents
            const privacyPolicyRadios = document.querySelectorAll('input[name="hasPrivacyPolicy"]');
            const privacyPolicyYes = document.getElementById('privacyPolicyYes');

            privacyPolicyRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        privacyPolicyYes.classList.add('show');
                    } else {
                        privacyPolicyYes.classList.remove('show');
                    }
                });
            });

            const termsRadios = document.querySelectorAll('input[name="hasTerms"]');
            const termsYes = document.getElementById('termsYes');

            termsRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.value === 'yes') {
                        termsYes.classList.add('show');
                    } else {
                        termsYes.classList.remove('show');
                    }
                });
            });

            // Dynamic Pages
            let pageCount = 0;
            const addPageBtn = document.getElementById('addPageBtn');
            const additionalPages = document.getElementById('additionalPages');
            
            addPageBtn.addEventListener('click', function() {
                pageCount++;
                const pageDiv = document.createElement('div');
                pageDiv.className = 'dynamic-item';
                pageDiv.innerHTML = `
                    <button type="button" class="btn btn-remove" onclick="this.parentElement.remove();">Remove</button>
                    <div class="form-group">
                        <label>Page Name</label>
                        <input type="text" name="additionalPageName_${pageCount}" placeholder="e.g., Portfolio, Testimonials">
                    </div>
                    <div class="form-group">
                        <label>Add to</label>
                        <select name="additionalPageType_${pageCount}">
                            <option value="header">Header (Main Navigation)</option>
                            <option value="footer">Footer (Footer Links)</option>
                        </select>
                    </div>
                    <button type="button" class="btn btn-add" onclick="addPageToCheckboxGroup(this)">Add to Website Structure</button>
                `;
                additionalPages.appendChild(pageDiv);
            });

            // Dynamic Content Fields based on selected pages
            const headerPagesCheckboxes = document.querySelectorAll('input[name="headerPages"]');
            const footerPagesCheckboxes = document.querySelectorAll('input[name="footerPages"]');
            const dynamicContentFields = document.getElementById('dynamicContentFields');

            // Listen for changes in headerPages checkboxes
            headerPagesCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    updateDynamicContentFields();
                    updateNavigationList();
                    updatePageCount();
                });
            });

            // Listen for changes in footerPages checkboxes
            footerPagesCheckboxes.forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    updateDynamicContentFields();
                    updateNavigationList();
                    updatePageCount();
                });
            });

            // Initialize dynamic content fields on page load
            updateDynamicContentFields();
            updateNavigationList();
            updatePageCount();

            // Form Validation and Submission
            const requirementForm = document.getElementById('requirementForm');

            requirementForm.addEventListener('submit', function(e) {
                e.preventDefault();
                console.log('Submit button clicked');

                // Show loader
                document.getElementById('loaderOverlay').classList.add('show');

                let isValid = true;
                let firstInvalidInput = null;
                const requiredInputs = requirementForm.querySelectorAll('[required]');
                console.log('Required inputs found:', requiredInputs.length);

                // Track radio button groups to avoid duplicate validation
                const radioGroups = new Set();

                requiredInputs.forEach(input => {
                    const formGroup = input.closest('.form-group');

                    // Skip if field is hidden (in conditional field)
                    const isHidden = input.closest('.conditional-field') &&
                                   !input.closest('.conditional-field').classList.contains('show');
                    if (isHidden) {
                        console.log(`Skipping hidden field: ${input.name}`);
                        return;
                    }

                    // Skip radio buttons if we've already validated this group
                    if (input.type === 'radio') {
                        if (radioGroups.has(input.name)) return;
                        radioGroups.add(input.name);

                        // Check if any radio in this group is checked
                        const radioGroup = requirementForm.querySelectorAll(`input[name="${input.name}"]`);
                        const isChecked = Array.from(radioGroup).some(radio => radio.checked);

                        console.log(`Radio group ${input.name}: checked = ${isChecked}`);

                        if (!isChecked) {
                            isValid = false;
                            formGroup.classList.add('error');
                            radioGroup.forEach(r => r.classList.add('error'));
                            if (!firstInvalidInput) {
                                firstInvalidInput = radioGroup[0];
                            }
                            console.log(`Radio group ${input.name} is invalid`);
                        } else {
                            formGroup.classList.remove('error');
                            radioGroup.forEach(r => r.classList.remove('error'));
                        }
                    } else {
                        // Handle other input types
                        console.log(`Input ${input.name}: value = "${input.value}"`);
                        if (!input.value.trim()) {
                            isValid = false;
                            formGroup.classList.add('error');
                            input.classList.add('error');
                            if (!firstInvalidInput) {
                                firstInvalidInput = input;
                            }
                            console.log(`Input ${input.name} is invalid (empty)`);
                        } else {
                            formGroup.classList.remove('error');
                            input.classList.remove('error');
                        }
                    }
                });

                console.log('Validation result:', isValid);

                // Scroll to first invalid field if validation fails
                if (!isValid && firstInvalidInput) {
                    // Hide loader
                    document.getElementById('loaderOverlay').classList.remove('show');

                    // Show the section containing the invalid field
                    const invalidSection = firstInvalidInput.closest('.form-section');
                    if (invalidSection) {
                        // Switch to the section
                        sections.forEach(section => {
                            section.classList.remove('active');
                            if (section.id === invalidSection.id) {
                                section.classList.add('active');
                            }
                        });

                        // Update sidebar navigation
                        navLinks.forEach(l => l.classList.remove('active'));
                        const activeLink = document.querySelector(`.nav-link[data-section="${invalidSection.id}"]`);
                        if (activeLink) {
                            activeLink.classList.add('active');
                        }
                    }

                    firstInvalidInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    firstInvalidInput.focus();
                    return;
                }

                // Email validation
                const emailInputs = requirementForm.querySelectorAll('input[type="email"]');
                emailInputs.forEach(input => {
                    const formGroup = input.closest('.form-group');
                    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                    if (input.value && !emailRegex.test(input.value)) {
                        isValid = false;
                        formGroup.classList.add('error');
                        input.classList.add('error');
                        if (!firstInvalidInput) {
                            firstInvalidInput = input;
                        }
                    }
                });

                // Scroll to first invalid email field if email validation fails
                if (!isValid && firstInvalidInput) {
                    const invalidSection = firstInvalidInput.closest('.form-section');
                    if (invalidSection) {
                        sections.forEach(section => {
                            section.classList.remove('active');
                            if (section.id === invalidSection.id) {
                                section.classList.add('active');
                            }
                        });

                        navLinks.forEach(l => l.classList.remove('active'));
                        const activeLink = document.querySelector(`.nav-link[data-section="${invalidSection.id}"]`);
                        if (activeLink) {
                            activeLink.classList.add('active');
                        }
                    }

                    firstInvalidInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    firstInvalidInput.focus();
                    return;
                }

                if (isValid) {
                    // Collect form data
                    const formData = new FormData(requirementForm);
                    const data = {};

                    // Add client ID to data
                    const clientId = generateClientId();
                    data.client_id = clientId;
                    console.log('Main form submission - Client ID added:', clientId);

                    // Handle regular form fields
                    formData.forEach((value, key) => {
                        if (key.includes('File')) return; // Skip file inputs, handle separately
                        if (data[key]) {
                            if (Array.isArray(data[key])) {
                                data[key].push(value);
                            } else {
                                data[key] = [data[key], value];
                            }
                        } else {
                            data[key] = value;
                        }
                    });

                    // Collect structured page content from dynamic fields
                    data.pageContents = {};
                    data.pageAttachments = {};
                    data.pageImages = {};
                    data.pageHeadings = {};
                    data.pageSubheadings = {};
                    
                    // Get all page headings
                    const pageHeadings = document.querySelectorAll('input[name^="pageHeading_"]');
                    pageHeadings.forEach(input => {
                        const pageName = input.name.replace('pageHeading_', '');
                        data.pageHeadings[pageName] = input.value;
                    });

                    // Get all page subheadings
                    const pageSubheadings = document.querySelectorAll('input[name^="pageSubheading_"]');
                    pageSubheadings.forEach(input => {
                        const pageName = input.name.replace('pageSubheading_', '');
                        data.pageSubheadings[pageName] = input.value;
                    });

                    // Get all dynamic content textareas
                    const contentTextareas = document.querySelectorAll('textarea[name^="content_"]');
                    contentTextareas.forEach(textarea => {
                        const pageName = textarea.name.replace('content_', '');
                        data.pageContents[pageName] = textarea.value;
                    });

                    // Get all page images
                    const pageImageInputs = document.querySelectorAll('input[name^="pageImage_"]');
                    pageImageInputs.forEach(input => {
                        if (input.files.length > 0) {
                            const pageName = input.name.replace('pageImage_', '');
                            console.log(`Found image for ${pageName}:`, input.files[0].name);
                        }
                    });

                    // Get all dynamic file inputs for pages
                    const pageFileInputs = document.querySelectorAll('input[type="file"][name^="content_"][name$="_file"]');
                    pageFileInputs.forEach(input => {
                        if (input.files.length > 0) {
                            const pageName = input.name.replace('content_', '').replace('_file', '');
                            console.log(`Found file for ${pageName}:`, input.files[0].name);
                        }
                    });

                    // Collect Contact Form Builder fields (if contact page exists)
                    const contactFormTitle = document.querySelector('input[name="contactFormTitle"]');
                    if (contactFormTitle) {
                        data.contactFormTitle = contactFormTitle.value;
                    }
                    const contactFormSubmitText = document.querySelector('input[name="contactFormSubmitText"]');
                    if (contactFormSubmitText) {
                        data.contactFormSubmitText = contactFormSubmitText.value;
                    }
                    const contactFormThankYou = document.querySelector('textarea[name="contactFormThankYou"]');
                    if (contactFormThankYou) {
                        data.contactFormThankYou = contactFormThankYou.value;
                    }
                    const contactFormAdminEmail = document.querySelector('input[name="contactFormAdminEmail"]');
                    if (contactFormAdminEmail) {
                        data.contactFormAdminEmail = contactFormAdminEmail.value;
                    }

                    // Collect Contact Form standard field checkboxes
                    const contactFieldName = document.querySelector('input[name="contactField_name"]');
                    if (contactFieldName) {
                        data.contactField_name = contactFieldName.checked ? 'yes' : 'no';
                    }
                    const contactFieldEmail = document.querySelector('input[name="contactField_email"]');
                    if (contactFieldEmail) {
                        data.contactField_email = contactFieldEmail.checked ? 'yes' : 'no';
                    }
                    const contactFieldPhone = document.querySelector('input[name="contactField_phone"]');
                    if (contactFieldPhone) {
                        data.contactField_phone = contactFieldPhone.checked ? 'yes' : 'no';
                    }
                    const contactFieldMessage = document.querySelector('input[name="contactField_message"]');
                    if (contactFieldMessage) {
                        data.contactField_message = contactFieldMessage.checked ? 'yes' : 'no';
                    }

                    // Collect Contact Form custom fields
                    const customFieldRows = document.querySelectorAll('.custom-field-row');
                    customFieldRows.forEach((row, index) => {
                        const labelInput = row.querySelector('input[name^="contactCustomField_"][name$="_label"]');
                        const typeSelect = row.querySelector('select[name^="contactCustomField_"][name$="_type"]');
                        if (labelInput && typeSelect) {
                            data[`contactCustomField_${index}_label`] = labelInput.value;
                            data[`contactCustomField_${index}_type`] = typeSelect.value;
                        }
                    });

                    // Handle file uploads
                    const fileInputs = requirementForm.querySelectorAll('input[type="file"]');
                    const filePromises = [];

                    fileInputs.forEach(input => {
                        if (input.files.length > 0) {
                            const file = input.files[0];
                            const reader = new FileReader();
                            const promise = new Promise((resolve) => {
                                reader.onload = function(e) {
                                    resolve({
                                        name: input.name,
                                        fileName: file.name,
                                        fileType: file.type,
                                        data: e.target.result
                                    });
                                };
                                reader.readAsDataURL(file);
                            });
                            filePromises.push(promise);
                        }
                    });

                    // Wait for all files to be processed
                    Promise.all(filePromises).then(fileResults => {
                        fileResults.forEach(file => {
                            // Check if this is a page image
                            if (file.name.startsWith('pageImage_')) {
                                const pageName = file.name.replace('pageImage_', '');
                                if (!data.pageImages) {
                                    data.pageImages = {};
                                }
                                data.pageImages[pageName] = {
                                    fileName: file.fileName,
                                    fileType: file.fileType,
                                    data: file.data
                                };
                            }
                            // Check if this is a page attachment
                            else if (file.name.startsWith('content_') && file.name.endsWith('_file')) {
                                const pageName = file.name.replace('content_', '').replace('_file', '');
                                if (!data.pageAttachments) {
                                    data.pageAttachments = {};
                                }
                                data.pageAttachments[pageName] = {
                                    fileName: file.fileName,
                                    fileType: file.fileType,
                                    data: file.data
                                };
                            } else {
                                // Regular file handling
                                data[file.name] = file.fileName;
                                data[file.name + '_type'] = file.fileType;
                                data[file.name + '_data'] = file.data;
                            }
                        });

                        // Log to console
                        console.log('Form Data Submitted:', JSON.stringify(data, null, 2));
                        console.log('Client ID being sent:', data.client_id);
                        console.log('Company Name being sent:', data.companyName);

                        // Send to PHP backend
                        let submitUrl;
                        // Check if running on localhost:8000 (development server)
                        if (window.location.port === '8000') {
                            submitUrl = 'http://localhost/Recharge%20form/submit_form.php';
                        } else if (window.location.pathname.includes('Recharge%20form')) {
                            submitUrl = window.location.origin + '/Recharge%20form/submit_form.php';
                        } else {
                            submitUrl = window.location.origin + window.location.pathname.replace(/\/[^\/]*$/, '/submit_form.php');
                        }
                        console.log('Submitting to:', submitUrl); // Debug log
                        console.log('Data size:', JSON.stringify(data).length, 'bytes');

                        // Add timeout to prevent infinite waiting
                        const controller = new AbortController();
                        const timeoutId = setTimeout(() => controller.abort(), 30000); // 30 second timeout

                        fetch(submitUrl, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify(data),
                            signal: controller.signal
                        })
                        .then(response => {
                            clearTimeout(timeoutId);
                            console.log('Response status:', response.status);
                            console.log('Response headers:', response.headers);

                            if (!response.ok) {
                                throw new Error(`HTTP error! status: ${response.status}`);
                            }
                            return response.text().then(text => {
                                console.log('Response text:', text);
                                try {
                                    return JSON.parse(text);
                                } catch (e) {
                                    console.error('JSON parse error:', e);
                                    throw new Error('Invalid JSON response from server');
                                }
                            });
                        })
                        .then(result => {
                            console.log('Success!', result);
                            // Hide loader
                            document.getElementById('loaderOverlay').classList.remove('show');

                            if (result.success) {
                                // Hide form and show thank you section
                                document.querySelector('.sidebar').style.display = 'none';
                                document.querySelector('.header').style.display = 'none';
                                document.querySelectorAll('.form-section').forEach(section => {
                                    section.style.display = 'none';
                                });
                                document.getElementById('thankYouSection').style.display = 'block';

                                // Update thank you message with client ID
                                const thankYouContent = document.querySelector('.thank-you-content');
                                thankYouContent.innerHTML = `
                                    <div class="thank-you-icon">✓</div>
                                    <h1>Thank You!</h1>
                                    <p>Your form has been successfully submitted.</p>
                                    <p><strong>Your Client ID: ${result.client_id}</strong></p>
                                    <p>Please save this ID for future reference.</p>
                                    <p>We will review your requirements and get back to you soon.</p>
                                `;

                                // Scroll to top
                                window.scrollTo({ top: 0, behavior: 'smooth' });
                                // Clear saved data after successful submission
                                localStorage.removeItem(STORAGE_KEY);
                                localStorage.removeItem(CLIENT_ID_KEY);
                            } else {
                                throw new Error(result.message || 'Submission failed');
                            }
                        })
                        .catch(error => {
                            clearTimeout(timeoutId);
                            console.error('Error!', error.message);
                            console.error('Error details:', error);
                            // Hide loader
                            document.getElementById('loaderOverlay').classList.remove('show');

                            // Show error message
                            const errorMessage = document.createElement('div');
                            errorMessage.className = 'error-message show';
                            errorMessage.style.background = '#fee';
                            errorMessage.style.color = '#c33';
                            errorMessage.style.padding = '20px';
                            errorMessage.style.borderRadius = '8px';
                            errorMessage.style.marginBottom = '20px';
                            errorMessage.style.textAlign = 'center';
                            errorMessage.innerHTML = `
                                <strong>Submission Error</strong><br>
                                There was an error submitting your form. Please try again or contact support.<br>
                                <small>Error: ${error.message}</small>
                            `;
                            
                            const form = document.getElementById('requirementForm');
                            form.parentNode.insertBefore(errorMessage, form);
                            
                            // Remove error message after 5 seconds
                            setTimeout(() => {
                                if (errorMessage.parentNode) {
                                    errorMessage.parentNode.removeChild(errorMessage);
                                }
                            }, 5000);
                        });
                    });
                } else {
                    // Scroll to first error
                    const firstError = requirementForm.querySelector('.error');
                    if (firstError) {
                        firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                }
            });

            // Remove error styling on input
            requirementForm.addEventListener('input', function(e) {
                if (e.target.classList.contains('error')) {
                    e.target.classList.remove('error');
                    e.target.closest('.form-group').classList.remove('error');
                }
            });

            // Display selected file name
            requirementForm.addEventListener('change', function(e) {
                if (e.target.classList.contains('file-input')) {
                    const fileNameSpan = e.target.parentElement.querySelector('.file-name');
                    if (e.target.files.length > 0) {
                        fileNameSpan.textContent = 'Selected: ' + e.target.files[0].name;
                    } else {
                        fileNameSpan.textContent = '';
                    }
                }
            });
        });

        // Password toggle function
        function togglePassword(fieldId) {
            const passwordField = document.getElementById(fieldId);
            const toggleBtn = passwordField.nextElementSibling;
            
            if (passwordField.type === 'password') {
                passwordField.type = 'text';
                toggleBtn.textContent = '🙈';
            } else {
                passwordField.type = 'password';
                toggleBtn.textContent = '👁️';
            }
        }
    </script>
</body>
</html>
