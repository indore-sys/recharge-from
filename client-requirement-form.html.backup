                    <div class="section-content">
                    
                    <!-- Section 6: Branding -->
                <div class="section">
                    <h2>6. Branding</h2>
                    <div class="form-group">
                        <label class="required">Company/Business Name</label>
                        <input type="text" name="companyName" required>
                        <div class="error-message">Please enter company name</div>
                    </div>

                    <div class="form-group">
                        <label class="checkbox-option" style="display: flex; align-items: center; gap: 8px; font-weight: 500; cursor: pointer;">
                            <input type="checkbox" id="addCompanyDetails" name="addCompanyDetails" value="yes" style="width: auto; margin: 0;">
                            Do you want to add Company details on website?
                        </label>
                    </div>

                    <div id="companyDetailsSection" class="conditional-field">
                        <div class="form-group">
                            <label>Company Code</label>
                            <input type="text" name="companyCode" placeholder="e.g., CMP-001">
                        </div>
                        <div class="form-group">
                            <label>GST / VAT Number</label>
                            <input type="text" name="gstNumber" placeholder="e.g., 27AABCU9603R1ZX">
                        </div>
                        <div class="form-group">
                            <label>Business Registration Number</label>
                            <input type="text" name="registrationNumber" placeholder="e.g., CIN: U72200MH2021PTC123456">
                        </div>
                        <div class="form-group">
                            <label>Bank Account Number / IBAN</label>
                            <input type="text" name="bankAccount" placeholder="e.g., 12345678901234">
                        </div>
                        <div class="form-group">
                            <label>Bank Name</label>
                            <input type="text" name="bankName" placeholder="e.g., State Bank of India">
                        </div>
                        <div class="form-group">
                            <label>IFSC / SWIFT Code</label>
                            <input type="text" name="ifscCode" placeholder="e.g., SBIN0001234 or SBININBBXXX">
                        </div>
                        <div class="form-group">
                            <label>Company Address</label>
                            <textarea name="companyAddress" placeholder="Enter complete company address..." rows="3"></textarea>
                        </div>
                        <div class="form-group">
                            <label>City</label>
                            <input type="text" name="city" placeholder="e.g., Mumbai">
                        </div>
                        <div class="form-group">
                            <label>State</label>
                            <input type="text" name="state" placeholder="e.g., Maharashtra">
                        </div>
                        <div class="form-group">
                            <label>Country</label>
                            <input type="text" name="country" placeholder="e.g., India">
                        </div>
                        <div class="form-group">
                            <label>Pincode</label>
                            <input type="text" name="pincode" placeholder="e.g., 400001">
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Tagline/Slogan</label>
                        <input type="text" name="tagline" placeholder="Your business tagline">
                    </div>
                    <div class="form-group">
                        <label>Do you have a logo?</label>
                        <div class="radio-group">
                            <label class="radio-option">
                                <input type="radio" name="hasLogo" value="yes"> Yes - I have logo
                            </label>
                            <label class="radio-option">
                                <input type="radio" name="hasLogo" value="no"> No - I need logo design
                            </label>
                        </div>
                    </div>
                    <div class="conditional-field" id="logoYes">
                        <div class="form-group">
                            <label>Logo File (Google Drive Link)</label>
                            <input type="url" name="logoLink" placeholder="https://drive.google.com/...">
                            <small style="color: #6c757d; margin-top: 5px; display: block;">Share the Google Drive link containing your logo file</small>
                        </div>
                        <div class="form-group">
                            <label>Or Upload Logo File</label>
                            <div class="file-upload">
                                <input type="file" name="logoFile" accept="image/*" class="file-input">
                                <span class="file-name">No file selected</span>
                                <small style="color: #6c757d; margin-top: 5px; display: block;">Upload logo file directly (JPG, PNG, GIF)</small>
                            </div>
                        </div>
                    </div>
                    <div class="conditional-field" id="logoNo">
                        <div class="form-group">
                            <label>Logo Size (Dimensions)</label>
                            <input type="text" name="logoSize" placeholder="e.g., 1724 x 363, 500 x 500">
                            <small style="color: #6c757d; margin-top: 5px; display: block;">Specify desired logo dimensions (width x height in pixels)</small>
                        </div>
                        <div class="form-group">
                            <label>Logo Colors & Symbols</label>
                            <textarea name="logoColors" placeholder="Describe preferred colors, symbols, or design elements for your logo..." rows="3"></textarea>
                            <small style="color: #6c757d; margin-top: 5px; display: block;">Mention specific colors, symbols, icons, or design elements you want in your logo</small>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Brand Guidelines</label>
                        <textarea name="brandGuidelines" placeholder="Share any brand guidelines, style guides, or brand assets..."></textarea>
                    </div>
                    <div class="form-group">
                        <label>Brand Voice/Tone</label>
                        <select name="brandVoice">
                            <option value="">Select brand voice</option>
                            <option value="professional">Professional</option>
